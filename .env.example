# Copy this file to .env. Never commit the real key.
MODEL_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://127.0.0.1:8000
OPENROUTER_APP_TITLE=Piper Agentic Memory
OPENROUTER_REASONING=false

# Capability router. It filters the free pool for image, tool, reasoning,
# and structured-output support required by each request.
ROUTER_MODEL=openrouter/free

# All roles use the router by default. Pin any role to a specific OpenRouter
# model slug later if you need deterministic behavior.
MAIN_MODEL=openrouter/free
VISION_MODEL=openrouter/free
MEMORY_MODEL=openrouter/free
BENCHMARK_MODEL=openrouter/free

# Optional NVIDIA fallback:
# MODEL_PROVIDER=nvidia
# NVIDIA_API_KEY=
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# MAIN_MODEL=nvidia/nemotron-3-ultra-550b-a55b
# VISION_MODEL=moonshotai/kimi-k2.6
# MEMORY_MODEL=moonshotai/kimi-k2.6

ENABLE_VISION_RECALL=true
ENABLE_MEMORY_LLM=true
MAX_RETRIEVED_MEMORIES=3

# A memory advances one decay stage for every inactive interval.
DECAY_INTERVAL_HOURS=24
